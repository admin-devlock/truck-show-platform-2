# Firebase web app config (public client keys — safe to expose in the browser bundle).
# Copy to .env.local and fill in from the Firebase console: Project settings → General →
# "Your apps" → SDK setup and configuration.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set to "true" to show the dev "continue as a guest" sign-in (anonymous auth).
NEXT_PUBLIC_ENABLE_GUEST=false
